# Telegram — получение заявок из контакт-формы /api/lead
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Microsoft Clarity (бесплатно, session replay + heatmaps)
# https://clarity.microsoft.com → New project → копируй Project ID
NEXT_PUBLIC_CLARITY_ID=

# Plausible (privacy-first аналитика, $9/мес)
# https://plausible.io — указать домен сайта
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=

# Google Analytics 4 (бесплатно, самая распространённая)
# https://analytics.google.com → Admin → Data Streams → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=
